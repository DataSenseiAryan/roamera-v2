{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "jsx": "react",
    "noEmit": true,
    "paths": {
      "@roamera/types": ["../types/src/index.ts"]
    }
  },
  "include": ["src/**/*", "../types/src/**/*"]
}
