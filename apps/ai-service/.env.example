# AI Provider
AI_PROVIDER=gemini          # gemini | groq | openai | anthropic
AI_FALLBACK_PROVIDER=groq

# API Keys (only the ones you need for your chosen provider(s))
GOOGLE_API_KEY=             # Gemini — https://aistudio.google.com/app/apikey (free)
GROQ_API_KEY=               # Groq   — https://console.groq.com (free)
OPENAI_API_KEY=             # OpenAI — optional, paid
ANTHROPIC_API_KEY=          # Anthropic — optional, paid

# Service auth (must match apps/api AI_SERVICE_SECRET)
AI_SERVICE_SECRET=dev-ai-service-secret-change-in-production-32

# Server
PORT=8000
NODE_ENV=development
