# Database
DATABASE_URL=file:data/app.db
# DATABASE_URL=libsql://your-db-name.turso.io   # Production Turso URL
# DATABASE_AUTH_TOKEN=                           # Required for Turso remote

# JWT
JWT_SECRET=your-jwt-secret-minimum-32-characters-long
JWT_REFRESH_SECRET=your-refresh-secret-minimum-32-characters-long
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AI Service
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_SECRET=your-ai-service-hmac-secret-32-chars

# Storage
STORAGE_DRIVER=local
# STORAGE_DRIVER=r2   # Use in production
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=roamera-uploads

# Email
# RESEND_API_KEY=re_xxxx

# CORS
CORS_ORIGINS=http://localhost:3001,http://localhost:8081

# External APIs (all optional / free-tier)
# AMADEUS_CLIENT_ID=
# AMADEUS_CLIENT_SECRET=
# PEXELS_API_KEY=
# FOURSQUARE_API_KEY=

# Observability (optional)
# SENTRY_DSN=

# App
NODE_ENV=development
PORT=3000
